// ZARODA POS — core schema.
// See ../../../DESIGN.md for the full design rationale (§4 entity model, §5 ERD).
//
// Row-Level Security: every tenant-owned table below carries organizationId.
// Prisma has no RLS DSL, so the actual `CREATE POLICY` statements live in
// prisma/rls.sql and are applied separately (see prisma/README.md) after
// `prisma migrate dev`. Do not treat this schema file as the full security
// boundary — the RLS policies are what actually enforce tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) - used at runtime
  directUrl = env("DIRECT_URL") // unpooled - used by `prisma migrate` only
}

// ─────────────────────────────────────────────────────────────────────────
// Identity / tenancy
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  CASHIER
  SUPERVISOR
  MANAGER
  OWNER
  AUDITOR
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  industryType  String // "RETAIL" | "RESTAURANT" | "PHARMACY" | "SALON" | ...
  country       String   @default("KE")
  baseCurrency  String   @default("KES") // ISO 4217 — see DESIGN.md §9
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branches       Branch[]
  orgUsers       OrgUser[]
  categories     Category[]
  products       Product[]
  taxClasses     TaxClass[]
  sales          Sale[]
  auditLogs      AuditLog[]
  stockTransfers StockTransfer[]
  stockTakes     StockTake[]
  lowStockAlerts LowStockAlert[]
  customers      Customer[]
  layaways       Layaway[]
  restaurantTables RestaurantTable[]
  kitchenStations  KitchenStation[]
  salonResources   SalonResource[]
  salonAppointments SalonAppointment[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  repackagings     Repackaging[]
  wasteLogs        WasteLog[]
  productionOrders ProductionOrder[]
  serviceJobs      ServiceJob[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  county         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  terminals            Terminal[]
  inventoryItems       InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  shifts               Shift[]
  sales                Sale[]
  stockTakes           StockTake[]
  transfersOut         StockTransfer[] @relation("TransferFromBranch")
  transfersIn          StockTransfer[] @relation("TransferToBranch")
  lowStockAlerts       LowStockAlert[]
  layaways             Layaway[]
  restaurantTables     RestaurantTable[]
  kitchenStations      KitchenStation[]
  salonResources       SalonResource[]
  salonAppointments    SalonAppointment[]
  purchaseOrders       PurchaseOrder[]
  repackagings         Repackaging[]
  wasteLogs            WasteLog[]
  productionOrders     ProductionOrder[]
  serviceJobs          ServiceJob[]

  @@index([organizationId])
  @@map("branches")
}

model Terminal {
  id          String    @id @default(uuid())
  branchId    String
  deviceLabel String
  appVersion  String?
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shifts          Shift[]
  sales           Sale[]
  cashierSessions CashierSession[]
  syncOutboxItems SyncOutbox[]

  @@index([branchId])
  @@map("terminals")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  // PIN is for terminal quick-login, hashed separately from the account
  // password - short PINs are only ever compared within an org+terminal
  // scope, never used to look a user up account-wide.
  pinHash      String?
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orgUsers OrgUser[]

  @@map("users")
}

// A user's membership in an organization, with an optional branch scope
// (null = access to all branches) and a role. One user can belong to
// multiple organizations (e.g. an accountant contracted to several shops).
model OrgUser {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  branchId       String? // null = all branches in the org
  role           Role
  // Soft-delete, not a row DELETE - an OrgUser is referenced by
  // everything it ever did (sales as cashier, discount/refund approvals,
  // audit log actions...), so removing the row outright would mean
  // either cascading away real transaction history or hitting FK
  // conflicts. Deactivating just blocks new login (both password and
  // PIN) and drops off the terminal's cashier picker by default -
  // history stays intact and queryable.
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  shiftsOpened    Shift[]          @relation("ShiftOpenedBy")
  salesCashier    Sale[]           @relation("SaleCashier")
  discounts       Discount[]       @relation("DiscountApprovedBy")
  refunds         Refund[]         @relation("RefundApprovedBy")
  auditActions    AuditLog[]       @relation("AuditActor")
  cashierSessions CashierSession[]
  stockTransfers  StockTransfer[]
  stockTakes      StockTake[]
  purchaseOrders  PurchaseOrder[]
  repackagings    Repackaging[]
  wasteLogs       WasteLog[]
  productionOrders ProductionOrder[]
  serviceJobs      ServiceJob[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("org_users")
}

// Shared-terminal PIN switching (DESIGN.md §9): a terminal is authenticated
// at the device level, but each sale is attributed to whichever cashier is
// currently "swiped in" here, not to the device session.
model CashierSession {
  id            String    @id @default(uuid())
  terminalId    String
  orgUserId     String
  pinStartedAt  DateTime  @default(now())
  pinEndedAt    DateTime?

  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  orgUser  OrgUser  @relation(fields: [orgUserId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([terminalId])
  @@index([orgUserId])
  @@map("cashier_sessions")
}

// ─────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@index([organizationId])
  @@map("categories")
}

model TaxClass {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  rate           Decimal @db.Decimal(6, 4) // e.g. 0.1600 for 16% VAT
  isExempt       Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@index([organizationId])
  @@map("tax_classes")
}

model Product {
  id             String   @id @default(uuid())
  organizationId String
  categoryId     String?
  taxClassId     String?
  name           String
  baseUnit       String   @default("each")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  taxClass     TaxClass?         @relation(fields: [taxClassId], references: [id], onDelete: SetNull)
  variants     ProductVariant[]
  pharmacyFlag PharmacyProductFlag?

  @@index([organizationId])
  @@map("products")
}

// COUNT = sold/stocked in whole units (each, pack, box - the default).
// WEIGHT = sold/stocked in fractional quantities of the variant's unit (kg,
// litre, ...) - a scoop of loose rice or a ladle of cooking oil doesn't
// come in fixed-size units, so quantity has to allow e.g. 0.35. Every
// quantity-bearing column downstream (sale/inventory/batch/transfer/
// purchase-order/repackaging) is Decimal(14,3) precisely so COUNT and
// WEIGHT variants can share the same columns - COUNT just never produces a
// fractional value, enforced in the service layer (see SalesService,
// InventoryTransactionsService) rather than at the database level, since
// Postgres has no per-row "this decimal must be an integer" constraint
// that's cheap to express here.
enum QuantityMode {
  COUNT
  WEIGHT
}

model ProductVariant {
  id           String       @id @default(uuid())
  productId    String
  sku          String
  barcode      String?
  price        Decimal      @db.Decimal(12, 2) // for WEIGHT variants, price per unit of quantity (e.g. per kg)
  quantityMode QuantityMode @default(COUNT)
  // Unit cost - optional (not every tenant tracks it), used only for the
  // COGS/margin report. Null cost means that report just omits margin for
  // this variant rather than treating cost as zero (a zero cost would
  // silently overstate margin).
  cost      Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItems       InventoryItem[]
  batches              Batch[]
  inventoryTransactions InventoryTransaction[]
  saleLineItems        SaleLineItem[]
  stockTransfers       StockTransfer[]
  stockTakeLines       StockTakeLine[]
  lowStockAlerts       LowStockAlert[]
  layawayLineItems     LayawayLineItem[]
  kitchenTicketLines   KitchenTicketLine[]
  purchaseOrderLineItems PurchaseOrderLineItem[]
  repackagedFrom       Repackaging[]         @relation("RepackagingFrom")
  repackagedInto       Repackaging[]         @relation("RepackagingTo")
  recipeIngredients    RecipeIngredient[]    @relation("RecipeFor")
  usedAsIngredientIn   RecipeIngredient[]    @relation("RecipeIngredientOf")
  ingredientOfSaleLines SaleLineItemIngredient[]
  wasteLogs            WasteLog[]
  ingredientOfWaste    WasteIngredient[]
  productionOrders     ProductionOrder[]

  @@unique([productId, sku])
  @@index([barcode])
  @@map("product_variants")
}

// A restaurant (or any processor) makes a sellable item out of raw
// materials rather than reselling something it bought as-is - a Chicken
// Biryani isn't received from a supplier, it's assembled from rice,
// chicken, and oil at cook time. Optional per DESIGN.md discussion: a
// ProductVariant with zero RecipeIngredient rows behaves exactly as it
// always has (its own stock is received and decremented directly - the
// right model for a resold-as-is item like a bottled drink); a variant
// WITH rows here instead has each ingredient's stock decremented on sale
// (see SalesService), and never carries its own InventoryItem - nothing
// ever "receives" a finished dish. Quantity is consumed per 1 unit of the
// parent variant sold, e.g. 0.2 (kg) rice per 1 Biryani.
model RecipeIngredient {
  id                  String   @id @default(uuid())
  variantId           String // the sellable dish
  ingredientVariantId String // the raw material consumed
  quantity             Decimal @db.Decimal(14, 3)
  createdAt            DateTime @default(now())

  variant           ProductVariant @relation("RecipeFor", fields: [variantId], references: [id], onDelete: Cascade)
  ingredientVariant ProductVariant @relation("RecipeIngredientOf", fields: [ingredientVariantId], references: [id], onDelete: Restrict)

  @@unique([variantId, ingredientVariantId])
  @@index([variantId])
  @@map("recipe_ingredients")
}

// A snapshot of exactly what a recipe-tracked sale line actually consumed,
// taken at sale time (see SalesService) - NOT a live re-derivation from
// RecipeIngredient, because a recipe can change (a substituted ingredient,
// an adjusted portion size) after the sale happened. Voiding a sale
// reverses these rows, not whatever the recipe says today - the same
// "snapshot what was actually agreed/consumed, don't trust it to still
// match the current catalog" principle as SaleLineItem.unitPrice/taxAmount.
model SaleLineItemIngredient {
  id                  String  @id @default(uuid())
  saleLineItemId      String
  ingredientVariantId String
  quantity             Decimal @db.Decimal(14, 3)

  saleLineItem      SaleLineItem   @relation(fields: [saleLineItemId], references: [id], onDelete: Cascade)
  ingredientVariant ProductVariant @relation(fields: [ingredientVariantId], references: [id], onDelete: Restrict)

  @@index([saleLineItemId])
  @@map("sale_line_item_ingredients")
}

// ─────────────────────────────────────────────────────────────────────────
// Inventory — append-only ledger is the source of truth (DESIGN.md §4).
// InventoryItem.quantity is derived/maintained from InventoryTransaction
// rows, never written to directly by application code outside that
// maintenance path.
// ─────────────────────────────────────────────────────────────────────────

model InventoryItem {
  id                String   @id @default(uuid())
  branchId          String
  variantId         String
  quantity          Decimal  @default(0) @db.Decimal(14, 3) // derived - see note above
  lowStockThreshold Decimal  @default(0) @db.Decimal(14, 3)
  updatedAt         DateTime @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId])
  @@map("inventory_items")
}

enum LowStockAlertStatus {
  OPEN
  RESOLVED
}

// Detected synchronously whenever InventoryTransactionsService.recordInTx
// moves a branch+variant's quantity across its lowStockThreshold (see that
// service) - no polling/cron needed since every quantity change already
// goes through one place. There is at most one OPEN alert per
// branch+variant at a time (re-crossing below the threshold while already
// OPEN does not create a duplicate); it auto-resolves the moment the
// quantity rises back above the threshold. This is the durable record a
// future SMS/notification worker (DESIGN.md Phase 2 roadmap - deferred
// until Redis/BullMQ and Africa's Talking credentials are provisioned)
// would consume, same pattern as how sale_payments already models M-Pesa
// fields ahead of the integration being wired up.
model LowStockAlert {
  id             String               @id @default(uuid())
  organizationId String
  branchId       String
  variantId      String
  quantity       Decimal              @db.Decimal(14, 3) // snapshot at the moment the alert opened
  threshold      Decimal              @db.Decimal(14, 3) // snapshot of InventoryItem.lowStockThreshold at that moment
  status         LowStockAlertStatus  @default(OPEN)
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([branchId, variantId, status])
  @@map("low_stock_alerts")
}

enum InventoryTxnType {
  SALE
  TRANSFER
  ADJUSTMENT
  STOCKTAKE
  RETURN
  REPACK
  WASTE
  PRODUCTION
}

model InventoryTransaction {
  id            String            @id @default(uuid())
  branchId      String
  variantId     String
  batchId       String?
  type          InventoryTxnType
  quantityDelta Decimal           @db.Decimal(14, 3) // signed
  referenceId   String? // sale_id / transfer_id / stocktake_id, loosely typed by design
  createdAt     DateTime          @default(now())

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch   Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([branchId, variantId])
  @@map("inventory_transactions")
}

// Batch/expiry tracking — a core capability (perishable retail stock needs
// it too), not pharmacy-exclusive. The pharmacy module adds *enforcement*
// (block sale of an expired/controlled batch) on top of this core table.
model Batch {
  id                String    @id @default(uuid())
  variantId         String
  batchNumber       String
  expiryDate        DateTime?
  quantityReceived  Decimal   @db.Decimal(14, 3)
  createdAt         DateTime  @default(now())

  variant               ProductVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventoryTransactions InventoryTransaction[]
  saleLineItems         SaleLineItem[]
  wasteLogs             WasteLog[]

  @@index([variantId])
  @@map("batches")
}

// A single-step transfer between two branches of the same organization -
// no in-transit/receiving workflow (nothing in the design calls for one at
// pilot scale), so it completes atomically: one TRANSFER-type
// InventoryTransaction (negative) at fromBranch, one (positive) at
// toBranch, both referencing this row's id, written in the same
// transaction as this record (see StockTransfersService).
model StockTransfer {
  id             String   @id @default(uuid())
  organizationId String
  fromBranchId   String
  toBranchId     String
  variantId      String
  quantity       Decimal  @db.Decimal(14, 3)
  notes          String?
  createdById    String
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromBranch   Branch         @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch     Branch         @relation("TransferToBranch", fields: [toBranchId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  createdBy    OrgUser        @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@map("stock_transfers")
}

// Breaking bulk stock into smaller resale units - buying a 20L jerrycan of
// cooking oil or a 50kg bag of rice and selling it off in Ksh 30-50
// scoops/portions is the normal shape of a Kenyan duka, not an edge case,
// so this is a first-class stock operation rather than a manual pair of
// adjustments. Always at a single branch (repackaging happens where the
// physical stock is), and always atomic: one REPACK InventoryTransaction
// decrementing the bulk variant, one REPACK InventoryTransaction
// incrementing the portioned variant, both referencing this row's id, all
// in the same transaction (see RepackagingService) - same shape as
// StockTransfer above, just within one branch instead of across two.
model Repackaging {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  fromVariantId  String // the bulk item consumed
  fromQuantity   Decimal  @db.Decimal(14, 3) // how many bulk units were broken down
  toVariantId    String // the resale-sized item produced
  toQuantity     Decimal  @db.Decimal(14, 3) // total resale units produced (the yield)
  notes          String?
  createdById    String
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch         @relation(fields: [branchId], references: [id])
  fromVariant  ProductVariant @relation("RepackagingFrom", fields: [fromVariantId], references: [id])
  toVariant    ProductVariant @relation("RepackagingTo", fields: [toVariantId], references: [id])
  createdBy    OrgUser        @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@map("repackagings")
}

// ─────────────────────────────────────────────────────────────────────────
// Manufacturing — raw materials transformed into finished goods for sale
// (bakery, brick-making...). A ProductionOrder generalizes Repackaging's
// 1-in/1-out shape to an N-ingredient BOM: the finished good's
// RecipeIngredient rows (already built for recipe-tracked sales, see
// RecipeIngredient above) double as the bill of materials here - no
// separate BOM table. Completing an order decrements every ingredient by
// (recipe quantity × actualQuantity) and increments the finished good by
// actualQuantity, both legs tagged PRODUCTION and referencing this row's
// id, in one transaction (see ProductionOrdersService) - same atomicity
// guarantee as Repackaging, just N ingredients instead of 1.
enum ProductionOrderStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrder {
  id               String                @id @default(uuid())
  organizationId   String
  branchId         String
  variantId        String // the finished good being produced
  plannedQuantity  Decimal               @db.Decimal(14, 3)
  actualQuantity   Decimal?              @db.Decimal(14, 3) // set on completion - the real yield, which can differ from planned
  status           ProductionOrderStatus @default(DRAFT)
  notes            String?
  createdById      String
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime              @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch         @relation(fields: [branchId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  createdBy    OrgUser        @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@map("production_orders")
}

enum WasteReason {
  EXPIRED
  DAMAGED
  SPOILED
  OVERPRODUCTION
  OTHER
}

// Disposing of stale/spoiled stock - or, for a recipe-tracked dish (see
// RecipeIngredient), of made-but-unsold food - as its own tracked reason,
// not a generic ADJUSTMENT indistinguishable from a stock-count
// correction. variantId is always the item that was actually thrown away
// (the raw material, or the finished dish); for a recipe-tracked variant
// nothing of its own was ever in stock, so WasteService instead decrements
// each ingredient (via WasteIngredient, the same snapshot-at-the-time
// shape as SaleLineItemIngredient) and this row's cost fields still
// reflect what was actually lost.
//
// unitCost/totalCost are snapshotted at write-off time (current
// ProductVariant.cost, or the summed current cost of a recipe's
// ingredients) - null when cost isn't known, same "don't fake a zero"
// rule as everywhere else costs are optional in this schema - so the
// waste report can total actual loss without a later cost change
// silently rewriting history.
model WasteLog {
  id             String      @id @default(uuid())
  organizationId String
  branchId       String
  variantId      String
  quantity       Decimal     @db.Decimal(14, 3)
  reason         WasteReason
  notes          String?
  // Which specific batch was written off - only meaningful for a plain
  // stocked item (a recipe-tracked variant has no batches of its own).
  batchId        String?
  unitCost       Decimal?    @db.Decimal(12, 2)
  totalCost      Decimal?    @db.Decimal(12, 2)
  createdById    String
  createdAt      DateTime    @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch             @relation(fields: [branchId], references: [id])
  variant      ProductVariant     @relation(fields: [variantId], references: [id])
  batch        Batch?             @relation(fields: [batchId], references: [id])
  createdBy    OrgUser            @relation(fields: [createdById], references: [id])
  ingredients  WasteIngredient[]

  @@index([organizationId])
  @@index([branchId])
  @@index([variantId])
  @@map("waste_logs")
}

model WasteIngredient {
  id                  String  @id @default(uuid())
  wasteLogId          String
  ingredientVariantId String
  quantity            Decimal @db.Decimal(14, 3)

  wasteLog          WasteLog       @relation(fields: [wasteLogId], references: [id], onDelete: Cascade)
  ingredientVariant ProductVariant @relation(fields: [ingredientVariantId], references: [id], onDelete: Restrict)

  @@index([wasteLogId])
  @@map("waste_ingredients")
}

enum StockTakeStatus {
  OPEN
  COMPLETED
}

// A physical stock count for a branch. Opening one snapshots the current
// system quantity for every variant with stock at that branch (so a count
// taken over several hours isn't compared against a moving target); each
// line is then filled in with what was actually counted, and completing
// the stock take reconciles any variance into the inventory ledger as
// ADJUSTMENT transactions - never a silent overwrite of InventoryItem.
model StockTake {
  id             String          @id @default(uuid())
  organizationId String
  branchId       String
  status         StockTakeStatus @default(OPEN)
  startedById    String
  completedAt    DateTime?
  createdAt      DateTime        @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  startedBy    OrgUser         @relation(fields: [startedById], references: [id])
  lines        StockTakeLine[]

  @@index([organizationId])
  @@index([branchId])
  @@map("stock_takes")
}

model StockTakeLine {
  id              String @id @default(uuid())
  stockTakeId     String
  variantId       String
  systemQuantity  Decimal @db.Decimal(14, 3)
  countedQuantity Decimal? @db.Decimal(14, 3)
  variance        Decimal? @db.Decimal(14, 3)

  stockTake StockTake      @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([stockTakeId, variantId])
  @@index([stockTakeId])
  @@map("stock_take_lines")
}

// ─────────────────────────────────────────────────────────────────────────
// Shifts / cash reconciliation
// ─────────────────────────────────────────────────────────────────────────

model Shift {
  id            String    @id @default(uuid())
  branchId      String
  terminalId    String
  openedById    String
  openingFloat  Decimal   @db.Decimal(12, 2) @default(0)
  countedCash   Decimal?  @db.Decimal(12, 2)
  variance      Decimal?  @db.Decimal(12, 2)
  openedAt      DateTime  @default(now())
  closedAt      DateTime?

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  openedBy OrgUser  @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  sales    Sale[]

  @@index([branchId])
  @@index([terminalId])
  @@map("shifts")
}

// ─────────────────────────────────────────────────────────────────────────
// Sales
// ─────────────────────────────────────────────────────────────────────────

enum SaleStatus {
  PENDING_SYNC
  COMPLETED
  VOIDED
}

// A tenant's repeat customer, tracked for loyalty points. Attaching a
// customer to a sale is always optional - most POS sales are anonymous
// walk-ins - so every FK to Customer is nullable.
model Customer {
  id            String   @id @default(uuid())
  organizationId String
  name          String
  // Not globally unique (a customer might share a phone or have none on
  // file), but unique per-org so lookup-by-phone at the register is
  // unambiguous within a tenant.
  phone         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]
  layaways     Layaway[]
  salonAppointments SalonAppointment[]
  serviceJobs       ServiceJob[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("customers")
}

model Sale {
  id                 String     @id @default(uuid())
  organizationId     String
  branchId           String
  terminalId         String
  shiftId            String?
  cashierSessionId   String
  customerId         String?
  // Client-generated UUID from the offline terminal - the idempotency key
  // for sync replay (DESIGN.md §6). Distinct from `id` so the server is
  // free to also assign its own id without colliding with client state.
  clientId           String     @unique
  status             SaleStatus @default(PENDING_SYNC)
  total              Decimal    @db.Decimal(12, 2)
  // Loyalty points earned/redeemed on this specific sale - denormalized
  // onto the sale (rather than only mutating Customer.loyaltyPoints) so
  // the sale receipt/history can always show what happened on that ticket
  // even after the customer's running balance has since moved on.
  pointsEarned       Int        @default(0)
  pointsRedeemed     Int        @default(0)
  priceDriftFlagged  Boolean    @default(false)
  createdAt          DateTime   @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  terminal       Terminal        @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  shift          Shift?          @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  cashierSession CashierSession  @relation(fields: [cashierSessionId], references: [id])
  cashier        OrgUser?        @relation("SaleCashier", fields: [cashierOrgUserId], references: [id])
  cashierOrgUserId String?
  customer       Customer?       @relation(fields: [customerId], references: [id])

  lineItems SaleLineItem[]
  payments  SalePayment[]
  discounts Discount[]
  refunds   Refund[]
  restaurantTable RestaurantSaleTable?
  restaurantTip   RestaurantSaleTip?
  kitchenTickets  KitchenTicket[]
  pharmacyPrescription PharmacySalePrescription?
  salonAppointmentSale SalonAppointmentSale?
  serviceJobSale       ServiceJobSale?

  @@index([organizationId])
  @@index([branchId])
  @@map("sales")
}

model SaleLineItem {
  id         String  @id @default(uuid())
  saleId     String
  variantId  String
  quantity   Decimal @db.Decimal(14, 3)
  unitPrice  Decimal @db.Decimal(12, 2)
  taxAmount  Decimal @db.Decimal(12, 2) @default(0)
  // Which batch this line was drawn from - core capability (see Batch's
  // comment), nullable since most sales don't track batches at all.
  // Denormalized onto the line item itself (not just implied via the
  // InventoryTransaction ledger) so a sale's own receipt/history can show
  // which batch/expiry a dispensed item came from without a join through
  // the ledger.
  batchId    String?

  sale        Sale                     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant     ProductVariant           @relation(fields: [variantId], references: [id])
  batch       Batch?                   @relation(fields: [batchId], references: [id])
  ingredients SaleLineItemIngredient[]

  @@index([saleId])
  @@map("sale_line_items")
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
  WALLET
}

model SalePayment {
  id                  String        @id @default(uuid())
  saleId              String
  method              PaymentMethod
  amount              Decimal       @db.Decimal(12, 2) // in org.baseCurrency
  providerReference   String?
  // M-Pesa always settles in KES regardless of org.baseCurrency - see
  // DESIGN.md §9. Both null for cash/card-in-base-currency payments.
  settlementCurrency  String?
  settlementAmount    Decimal?      @db.Decimal(12, 2)
  createdAt           DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_payments")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Discount {
  id         String       @id @default(uuid())
  saleId     String
  type       DiscountType
  value      Decimal      @db.Decimal(12, 2)
  approvedById String

  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  approvedBy OrgUser @relation("DiscountApprovedBy", fields: [approvedById], references: [id])

  @@index([saleId])
  @@map("discounts")
}

model Refund {
  id           String   @id @default(uuid())
  saleId       String
  amount       Decimal  @db.Decimal(12, 2)
  reason       String
  approvedById String
  createdAt    DateTime @default(now())

  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  approvedBy OrgUser @relation("RefundApprovedBy", fields: [approvedById], references: [id])

  @@index([saleId])
  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────────────────
// Layaway - a customer reserves items and pays them off over time before
// pickup. Deliberately does NOT hold/reserve inventory at creation (that
// would need a new inventory-transaction type just to represent a
// non-committal hold, and this pilot's stock-conflict philosophy is
// already "never block, reconcile after the fact" - DESIGN.md §6). Stock
// is only actually decremented at completion/pickup, via the same
// InventoryTransactionsService.recordInTx used by sales.
// ─────────────────────────────────────────────────────────────────────────

enum LayawayStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model Layaway {
  id             String        @id @default(uuid())
  organizationId String
  branchId       String
  customerId     String
  status         LayawayStatus @default(OPEN)
  total          Decimal       @db.Decimal(12, 2)
  depositPaid    Decimal       @db.Decimal(12, 2) @default(0)
  createdAt      DateTime      @default(now())
  completedAt    DateTime?
  cancelledAt    DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  lineItems    LayawayLineItem[]
  payments     LayawayPayment[]

  @@index([organizationId])
  @@index([branchId])
  @@map("layaways")
}

model LayawayLineItem {
  id        String  @id @default(uuid())
  layawayId String
  variantId String
  quantity  Decimal @db.Decimal(14, 3)
  unitPrice Decimal @db.Decimal(12, 2)
  taxAmount Decimal @db.Decimal(12, 2) @default(0)

  layaway Layaway        @relation(fields: [layawayId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([layawayId])
  @@map("layaway_line_items")
}

model LayawayPayment {
  id        String        @id @default(uuid())
  layawayId String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  createdAt DateTime      @default(now())

  layaway Layaway @relation(fields: [layawayId], references: [id], onDelete: Cascade)

  @@index([layawayId])
  @@map("layaway_payments")
}

// ─────────────────────────────────────────────────────────────────────────
// Offline sync (DESIGN.md §6)
// ─────────────────────────────────────────────────────────────────────────

enum SyncStatus {
  PENDING
  APPLIED
  FAILED
}

model SyncOutbox {
  id         String     @id @default(uuid())
  terminalId String
  eventType  String
  payload    Json
  // The idempotency key - matches the client-generated id on the record the
  // event creates/mutates (e.g. Sale.clientId). Replays are safe no-ops.
  clientId   String     @unique
  status     SyncStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  appliedAt  DateTime?

  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@index([terminalId, status])
  @@map("sync_outbox")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit log — append-only. Nothing in this table is ever updated/deleted by
// application code.
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  terminalId     String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        OrgUser?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────────────────
// Restaurant vertical module (Phase 4, packages/modules/restaurant) —
// entityExtensions/transactionExtensions per DESIGN.md §3.
//
// A genuine limitation of this stack worth stating plainly rather than
// glossing over: Prisma has no supported way to split one database's
// schema across multiple independently-migrated schema.prisma files, so
// a vertical module's own tables still have to be declared in this one
// shared file even though the module's *code* (services, controllers,
// the manifest) lives entirely under packages/modules/restaurant and is
// never imported by core. "Zero changes to core packages" (DESIGN.md's
// Phase 4 success criterion) means zero changes to core's TypeScript
// business logic - SalesService, InventoryTransactionsService, etc. were
// not touched to add this vertical, only extended via the emit() calls
// already wired for the module contract in general, not for restaurant
// specifically. The schema file is shared infrastructure every module
// extends into, the same way every module shares one Postgres instance.
// ─────────────────────────────────────────────────────────────────────────

enum RestaurantTableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  NEEDS_CLEANING
}

model RestaurantTable {
  id             String                @id @default(uuid())
  organizationId String
  branchId       String
  label          String // e.g. "Table 4", "Patio 2" - free text, not a seat map (out of scope for this slice)
  seats          Int
  status         RestaurantTableStatus @default(AVAILABLE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  saleLinks    RestaurantSaleTable[]

  @@unique([branchId, label])
  @@index([organizationId])
  @@map("restaurant_tables")
}

// The transactionExtensions pattern from DESIGN.md §3: a dedicated 1:1
// extension table linking a core Sale to a module-owned entity, rather
// than a JSONB blob on Sale itself or (worse) a nullable tableId column
// added directly to the core sales table. Core's Sale model was not
// touched to add this - the restaurant module's own controller creates
// this row itself, in the same request that calls core's
// SalesService.create(), immediately after the sale is returned.
model RestaurantSaleTable {
  id      String @id @default(uuid())
  saleId  String @unique
  tableId String

  sale  Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  table RestaurantTable @relation(fields: [tableId], references: [id])

  @@map("restaurant_sale_tables")
}

// Also transactionExtensions, same reasoning as RestaurantSaleTable.
// Deliberately NOT folded into Sale.total/SalePayment: core's total is
// the amount owed for goods+tax and is what loyalty points are earned
// on (SalesService.create()'s LOYALTY_EARN_RATE math) and what shift
// cash-reconciliation sums (ShiftsService) - mixing tip money into it
// would silently inflate both. A tip/service charge is tracked here as
// parallel revenue the restaurant module reports on independently,
// collected as extra cash alongside the sale's own exact-total payment
// rather than folded into SalePayment.amount.
model RestaurantSaleTip {
  id                  String   @id @default(uuid())
  saleId              String   @unique
  tipAmount           Decimal  @default(0) @db.Decimal(12, 2)
  serviceChargeAmount Decimal  @default(0) @db.Decimal(12, 2)
  createdAt           DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("restaurant_sale_tips")
}

// Order-to-KDS routing + course timing. A station is a physical/logical
// kitchen prep area ("Grill", "Bar", "Cold") - entityExtensions, a new
// first-class entity this module owns outright.
model KitchenStation {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  name           String
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tickets      KitchenTicket[]

  @@unique([branchId, name])
  @@index([organizationId])
  @@map("kitchen_stations")
}

enum KitchenTicketStatus {
  HELD // course not fired yet - not visible on the KDS screen
  QUEUED // fired, waiting for the kitchen to start it
  IN_PROGRESS
  READY
  SERVED
}

// One ticket per (sale, station, course) - a table's order is split
// across however many stations its items route to, so "the kitchen"
// sees one focused ticket per prep area rather than a single ticket
// listing items three different stations need to independently track.
model KitchenTicket {
  id           String              @id @default(uuid())
  saleId       String
  stationId    String
  courseNumber Int                 @default(1)
  status       KitchenTicketStatus @default(QUEUED)
  firedAt      DateTime?
  startedAt    DateTime?
  readyAt      DateTime?
  servedAt     DateTime?
  createdAt    DateTime            @default(now())

  sale    Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  station KitchenStation      @relation(fields: [stationId], references: [id])
  lines   KitchenTicketLine[]

  @@index([stationId, status])
  @@map("kitchen_tickets")
}

model KitchenTicketLine {
  id        String  @id @default(uuid())
  ticketId  String
  variantId String
  quantity  Int
  notes     String?

  ticket  KitchenTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([ticketId])
  @@map("kitchen_ticket_lines")
}

// ─────────────────────────────────────────────────────────────────────────
// Pharmacy vertical module (Phase 5, apps/api/src/pharmacy) — batch/expiry
// enforcement (already built) plus these two: controlled-substance flags
// and prescription linkage.
//
// Unlike Batch (explicitly core - see that model's comment), whether a
// product is a controlled substance is pharmacy-specific policy, not
// something core's catalog needs to know about - kept as a pharmacy-owned
// extension table (entityExtensions per DESIGN.md §3) rather than a
// column added to core's Product model.
// ─────────────────────────────────────────────────────────────────────────

model PharmacyProductFlag {
  id                    String   @id @default(uuid())
  productId             String   @unique
  isControlledSubstance Boolean  @default(false)
  // Free-text classification (e.g. a Schedule/class designation) - not an
  // enum, since these vary by jurisdiction and this pilot doesn't need to
  // encode any particular regulatory scheme's exact categories.
  schedule              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("pharmacy_product_flags")
}

// transactionExtensions pattern, same as RestaurantSaleTable/
// RestaurantSaleTip: a dedicated 1:1 link rather than JSONB on Sale or a
// column added to it. Deliberately created by PharmacySalesService as the
// direct caller of SalesService.create() (POST /pharmacy/sales), not via
// an afterComplete hook - Phase 4's restaurant work already found and
// documented why a hook can't see extension data its own caller hasn't
// written yet, so a controlled-substance sale's prescription requirement
// is validated BEFORE core is ever called, not after the fact.
model PharmacySalePrescription {
  id                 String   @id @default(uuid())
  saleId             String   @unique
  prescriptionNumber String
  prescriberName     String
  issuedDate         DateTime
  createdAt          DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("pharmacy_sale_prescriptions")
}

// ─────────────────────────────────────────────────────────────────────────
// Salon vertical module (Phase 5+, apps/api/src/salon) — appointment/
// resource scheduling, DESIGN.md's remaining Phase 5+ vertical.
//
// Deliberately no transactionExtensions/hooks into core in this first
// slice - unlike restaurant/pharmacy, booking an appointment doesn't need
// to touch SalesService at all. Linking a completed appointment to a
// checkout sale (the same "module calls into core" pattern proven twice
// already) is a natural follow-up slice, not folded into this one.
// ─────────────────────────────────────────────────────────────────────────

model SalonResource {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  // e.g. "Stylist: Jane", "Chair 2" - a resource is whatever the branch
  // actually needs to schedule against (a person, a chair, a room), not
  // modeled as separate staff/room entities since a pilot-scale salon's
  // real constraint is usually "how many of X can we book at once."
  name           String
  createdAt      DateTime @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointments SalonAppointment[]

  @@unique([branchId, name])
  @@index([organizationId])
  @@map("salon_resources")
}

enum SalonAppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model SalonAppointment {
  id             String                 @id @default(uuid())
  organizationId String
  branchId       String
  resourceId     String
  customerId     String?
  // Free text for this slice ("Haircut", "Manicure") rather than linked
  // to a core Product - a real service-catalog integration (with
  // pricing feeding into a checkout sale) is exactly the kind of
  // follow-up slice noted above, not needed for scheduling itself to be
  // useful on its own.
  serviceName    String
  startTime      DateTime
  endTime        DateTime
  status         SalonAppointmentStatus @default(SCHEDULED)
  notes          String?
  // A random, unguessable value generated at creation the same way `id`
  // above already is (@default(uuid())) - the only "credential" a
  // public, unauthenticated customer has to view/cancel their own
  // booking later (public-booking module). Never returned by any
  // staff-facing endpoint - staff already reach any appointment through
  // their own authenticated session, they don't need this. Not a
  // password (nothing to remember/type) - a capability token embedded in
  // a link, the same shape as an unsubscribe link or a password-reset
  // link elsewhere on the web.
  cancelToken    String                 @unique @default(uuid())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  resource     SalonResource @relation(fields: [resourceId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])
  sale         SalonAppointmentSale?

  @@index([resourceId, startTime])
  @@index([organizationId])
  @@map("salon_appointments")
}

// transactionExtensions pattern, same as RestaurantSaleTable/
// PharmacySalePrescription: a dedicated 1:1 link between a core Sale and
// this module's own entity, created by SalonAppointmentsService as the
// direct caller of SalesService.create() (POST
// /salon/appointments/:id/checkout), not via a hook - the same reasoning
// already documented twice: a hook can't see extension data its own
// caller hasn't written yet, and can't retroactively undo a sale that
// already committed. Core's line items still reference real
// ProductVariants (checkout needs an actual catalog price to charge),
// unlike SalonAppointment.serviceName which stays free text - a deeper
// service-catalog integration is a further follow-up, not this slice.
model SalonAppointmentSale {
  id            String @id @default(uuid())
  appointmentId String @unique
  saleId        String @unique

  appointment SalonAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("salon_appointment_sales")
}

// ─────────────────────────────────────────────────────────────────────────
// Service industry — job/work-order businesses that bill labor and parts
// against a customer's asset (garage: a vehicle; transport: a route/run).
// `assetLabel` stays free text (plate number, route name...) the same way
// SalonAppointment.serviceName does, rather than a dedicated Vehicle model
// - keeps this generic across very different service businesses. No
// line-item table of its own: invoicing reuses core's SaleLineItemInputDto
// directly (parts AND labor are both just catalog ProductVariants - a
// "Labor" service item priced per hour, quantity = hours billed), the
// exact same "module composes a checkout sale from core's DTO" pattern as
// SalonAppointmentSalesService/CheckoutAppointmentDto.
enum ServiceJobStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  CANCELLED
}

model ServiceJob {
  id             String           @id @default(uuid())
  organizationId String
  branchId       String
  customerId     String?
  assetLabel     String? // e.g. a vehicle plate or a transport route/run reference
  description    String
  status         ServiceJobStatus @default(OPEN)
  notes          String?
  createdById    String
  closedAt       DateTime?
  createdAt      DateTime         @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch          @relation(fields: [branchId], references: [id])
  customer     Customer?       @relation(fields: [customerId], references: [id])
  createdBy    OrgUser         @relation(fields: [createdById], references: [id])
  sale         ServiceJobSale?

  @@index([organizationId])
  @@index([branchId])
  @@map("service_jobs")
}

model ServiceJobSale {
  id     String @id @default(uuid())
  jobId  String @unique
  saleId String @unique

  job  ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sale Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("service_job_sales")
}

// ─────────────────────────────────────────────────────────────────────────
// Purchasing — suppliers and the purchase orders raised against them.
// Receiving stock ad-hoc (no PO) still goes through Batch/InventoryTransaction
// directly (see BatchesService) - a PurchaseOrder is the optional paper
// trail of "what did we expect to arrive, from whom, and how much of it
// actually has" on top of that same receiving path, not a replacement path.

model Supplier {
  id        String   @id @default(uuid())
  organizationId String
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  organizationId String
  branchId       String // receiving branch
  supplierId     String
  status         PurchaseOrderStatus @default(DRAFT)
  reference      String? // supplier's own invoice/PO number, free text
  notes          String?
  createdById    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier     Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy    OrgUser                 @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lineItems    PurchaseOrderLineItem[]

  @@index([organizationId])
  @@index([branchId])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id               String   @id @default(uuid())
  purchaseOrderId  String
  variantId        String
  quantityOrdered  Decimal  @db.Decimal(14, 3)
  // Denormalized running total, updated every time a receipt is recorded
  // against this line - the same "derived value maintained alongside the
  // append-only ledger" shape as InventoryItem.quantity (see its comment):
  // the ledger entry (InventoryTransaction, referenceId = this PO's id) is
  // the source of truth, this column is just the fast-read total.
  quantityReceived Decimal  @default(0) @db.Decimal(14, 3)
  unitCost         Decimal? @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([variantId])
  @@map("purchase_order_line_items")
}

// ─────────────────────────────────────────────────────────────────────────
// Platform admin — genuinely cross-tenant, not owned by any Organization.
// No RLS policy in rls.sql for either table below, deliberately: RLS
// exists to isolate tenant data from OTHER tenants, and neither of these
// tables is tenant data in the first place. Isolating them from
// tenant-facing requests is instead enforced at the application layer -
// PlatformAdminAuthGuard is the only thing that can ever authenticate a
// request against these tables (see platform-admin/ module), and no
// tenant-facing controller ever queries them.

model PlatformAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLog PlatformAuditLog[]

  @@map("platform_admins")
}

// A platform admin can see across every tenant - a materially more
// sensitive capability than anything an OrgUser has, so every action
// (including reads, unlike the tenant-scoped AuditLog which only logs
// writes) gets a row here, not just mutations.
model PlatformAuditLog {
  id              String   @id @default(uuid())
  platformAdminId String
  action          String
  entityType      String
  entityId        String?
  organizationId  String? // informational only - not an FK, since the referenced org may later be deleted and this log should outlive it
  createdAt       DateTime @default(now())

  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: Cascade)

  @@index([platformAdminId])
  @@map("platform_audit_log")
}

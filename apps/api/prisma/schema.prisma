// ZARODA POS — core schema.
// See ../../../DESIGN.md for the full design rationale (§4 entity model, §5 ERD).
//
// Row-Level Security: every tenant-owned table below carries organizationId.
// Prisma has no RLS DSL, so the actual `CREATE POLICY` statements live in
// prisma/rls.sql and are applied separately (see prisma/README.md) after
// `prisma migrate dev`. Do not treat this schema file as the full security
// boundary — the RLS policies are what actually enforce tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) - used at runtime
  directUrl = env("DIRECT_URL") // unpooled - used by `prisma migrate` only
}

// ─────────────────────────────────────────────────────────────────────────
// Identity / tenancy
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  CASHIER
  SUPERVISOR
  MANAGER
  OWNER
  AUDITOR
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  industryType  String // "RETAIL" | "RESTAURANT" | "PHARMACY" | "SALON" | ...
  country       String   @default("KE")
  baseCurrency  String   @default("KES") // ISO 4217 — see DESIGN.md §9
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branches       Branch[]
  orgUsers       OrgUser[]
  categories     Category[]
  products       Product[]
  taxClasses     TaxClass[]
  sales          Sale[]
  auditLogs      AuditLog[]
  stockTransfers StockTransfer[]
  stockTakes     StockTake[]
  lowStockAlerts LowStockAlert[]
  customers      Customer[]
  layaways       Layaway[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  county         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  terminals            Terminal[]
  inventoryItems       InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  shifts               Shift[]
  sales                Sale[]
  stockTakes           StockTake[]
  transfersOut         StockTransfer[] @relation("TransferFromBranch")
  transfersIn          StockTransfer[] @relation("TransferToBranch")
  lowStockAlerts       LowStockAlert[]
  layaways             Layaway[]

  @@index([organizationId])
  @@map("branches")
}

model Terminal {
  id          String    @id @default(uuid())
  branchId    String
  deviceLabel String
  appVersion  String?
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shifts          Shift[]
  sales           Sale[]
  cashierSessions CashierSession[]
  syncOutboxItems SyncOutbox[]

  @@index([branchId])
  @@map("terminals")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  // PIN is for terminal quick-login, hashed separately from the account
  // password - short PINs are only ever compared within an org+terminal
  // scope, never used to look a user up account-wide.
  pinHash      String?
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orgUsers OrgUser[]

  @@map("users")
}

// A user's membership in an organization, with an optional branch scope
// (null = access to all branches) and a role. One user can belong to
// multiple organizations (e.g. an accountant contracted to several shops).
model OrgUser {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  branchId       String? // null = all branches in the org
  role           Role
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  shiftsOpened    Shift[]          @relation("ShiftOpenedBy")
  salesCashier    Sale[]           @relation("SaleCashier")
  discounts       Discount[]       @relation("DiscountApprovedBy")
  refunds         Refund[]         @relation("RefundApprovedBy")
  auditActions    AuditLog[]       @relation("AuditActor")
  cashierSessions CashierSession[]
  stockTransfers  StockTransfer[]
  stockTakes      StockTake[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("org_users")
}

// Shared-terminal PIN switching (DESIGN.md §9): a terminal is authenticated
// at the device level, but each sale is attributed to whichever cashier is
// currently "swiped in" here, not to the device session.
model CashierSession {
  id            String    @id @default(uuid())
  terminalId    String
  orgUserId     String
  pinStartedAt  DateTime  @default(now())
  pinEndedAt    DateTime?

  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  orgUser  OrgUser  @relation(fields: [orgUserId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([terminalId])
  @@index([orgUserId])
  @@map("cashier_sessions")
}

// ─────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@index([organizationId])
  @@map("categories")
}

model TaxClass {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  rate           Decimal @db.Decimal(6, 4) // e.g. 0.1600 for 16% VAT
  isExempt       Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@index([organizationId])
  @@map("tax_classes")
}

model Product {
  id             String   @id @default(uuid())
  organizationId String
  categoryId     String?
  taxClassId     String?
  name           String
  baseUnit       String   @default("each")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  taxClass     TaxClass?         @relation(fields: [taxClassId], references: [id], onDelete: SetNull)
  variants     ProductVariant[]

  @@index([organizationId])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  sku       String
  barcode   String?
  price     Decimal  @db.Decimal(12, 2)
  // Unit cost - optional (not every tenant tracks it), used only for the
  // COGS/margin report. Null cost means that report just omits margin for
  // this variant rather than treating cost as zero (a zero cost would
  // silently overstate margin).
  cost      Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItems       InventoryItem[]
  batches              Batch[]
  inventoryTransactions InventoryTransaction[]
  saleLineItems        SaleLineItem[]
  stockTransfers       StockTransfer[]
  stockTakeLines       StockTakeLine[]
  lowStockAlerts       LowStockAlert[]
  layawayLineItems     LayawayLineItem[]

  @@unique([productId, sku])
  @@index([barcode])
  @@map("product_variants")
}

// ─────────────────────────────────────────────────────────────────────────
// Inventory — append-only ledger is the source of truth (DESIGN.md §4).
// InventoryItem.quantity is derived/maintained from InventoryTransaction
// rows, never written to directly by application code outside that
// maintenance path.
// ─────────────────────────────────────────────────────────────────────────

model InventoryItem {
  id                String   @id @default(uuid())
  branchId          String
  variantId         String
  quantity          Int      @default(0) // derived - see note above
  lowStockThreshold Int      @default(0)
  updatedAt         DateTime @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId])
  @@map("inventory_items")
}

enum LowStockAlertStatus {
  OPEN
  RESOLVED
}

// Detected synchronously whenever InventoryTransactionsService.recordInTx
// moves a branch+variant's quantity across its lowStockThreshold (see that
// service) - no polling/cron needed since every quantity change already
// goes through one place. There is at most one OPEN alert per
// branch+variant at a time (re-crossing below the threshold while already
// OPEN does not create a duplicate); it auto-resolves the moment the
// quantity rises back above the threshold. This is the durable record a
// future SMS/notification worker (DESIGN.md Phase 2 roadmap - deferred
// until Redis/BullMQ and Africa's Talking credentials are provisioned)
// would consume, same pattern as how sale_payments already models M-Pesa
// fields ahead of the integration being wired up.
model LowStockAlert {
  id             String               @id @default(uuid())
  organizationId String
  branchId       String
  variantId      String
  quantity       Int // snapshot at the moment the alert opened
  threshold      Int // snapshot of InventoryItem.lowStockThreshold at that moment
  status         LowStockAlertStatus  @default(OPEN)
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([branchId, variantId, status])
  @@map("low_stock_alerts")
}

enum InventoryTxnType {
  SALE
  TRANSFER
  ADJUSTMENT
  STOCKTAKE
  RETURN
}

model InventoryTransaction {
  id            String            @id @default(uuid())
  branchId      String
  variantId     String
  batchId       String?
  type          InventoryTxnType
  quantityDelta Int // signed
  referenceId   String? // sale_id / transfer_id / stocktake_id, loosely typed by design
  createdAt     DateTime          @default(now())

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch   Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([branchId, variantId])
  @@map("inventory_transactions")
}

// Batch/expiry tracking — a core capability (perishable retail stock needs
// it too), not pharmacy-exclusive. The pharmacy module adds *enforcement*
// (block sale of an expired/controlled batch) on top of this core table.
model Batch {
  id                String    @id @default(uuid())
  variantId         String
  batchNumber       String
  expiryDate        DateTime?
  quantityReceived  Int
  createdAt         DateTime  @default(now())

  variant               ProductVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventoryTransactions InventoryTransaction[]

  @@index([variantId])
  @@map("batches")
}

// A single-step transfer between two branches of the same organization -
// no in-transit/receiving workflow (nothing in the design calls for one at
// pilot scale), so it completes atomically: one TRANSFER-type
// InventoryTransaction (negative) at fromBranch, one (positive) at
// toBranch, both referencing this row's id, written in the same
// transaction as this record (see StockTransfersService).
model StockTransfer {
  id             String   @id @default(uuid())
  organizationId String
  fromBranchId   String
  toBranchId     String
  variantId      String
  quantity       Int
  notes          String?
  createdById    String
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromBranch   Branch         @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch     Branch         @relation("TransferToBranch", fields: [toBranchId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  createdBy    OrgUser        @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@map("stock_transfers")
}

enum StockTakeStatus {
  OPEN
  COMPLETED
}

// A physical stock count for a branch. Opening one snapshots the current
// system quantity for every variant with stock at that branch (so a count
// taken over several hours isn't compared against a moving target); each
// line is then filled in with what was actually counted, and completing
// the stock take reconciles any variance into the inventory ledger as
// ADJUSTMENT transactions - never a silent overwrite of InventoryItem.
model StockTake {
  id             String          @id @default(uuid())
  organizationId String
  branchId       String
  status         StockTakeStatus @default(OPEN)
  startedById    String
  completedAt    DateTime?
  createdAt      DateTime        @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  startedBy    OrgUser         @relation(fields: [startedById], references: [id])
  lines        StockTakeLine[]

  @@index([organizationId])
  @@index([branchId])
  @@map("stock_takes")
}

model StockTakeLine {
  id              String @id @default(uuid())
  stockTakeId     String
  variantId       String
  systemQuantity  Int
  countedQuantity Int?
  variance        Int?

  stockTake StockTake      @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([stockTakeId, variantId])
  @@index([stockTakeId])
  @@map("stock_take_lines")
}

// ─────────────────────────────────────────────────────────────────────────
// Shifts / cash reconciliation
// ─────────────────────────────────────────────────────────────────────────

model Shift {
  id            String    @id @default(uuid())
  branchId      String
  terminalId    String
  openedById    String
  openingFloat  Decimal   @db.Decimal(12, 2) @default(0)
  countedCash   Decimal?  @db.Decimal(12, 2)
  variance      Decimal?  @db.Decimal(12, 2)
  openedAt      DateTime  @default(now())
  closedAt      DateTime?

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  openedBy OrgUser  @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  sales    Sale[]

  @@index([branchId])
  @@index([terminalId])
  @@map("shifts")
}

// ─────────────────────────────────────────────────────────────────────────
// Sales
// ─────────────────────────────────────────────────────────────────────────

enum SaleStatus {
  PENDING_SYNC
  COMPLETED
  VOIDED
}

// A tenant's repeat customer, tracked for loyalty points. Attaching a
// customer to a sale is always optional - most POS sales are anonymous
// walk-ins - so every FK to Customer is nullable.
model Customer {
  id            String   @id @default(uuid())
  organizationId String
  name          String
  // Not globally unique (a customer might share a phone or have none on
  // file), but unique per-org so lookup-by-phone at the register is
  // unambiguous within a tenant.
  phone         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]
  layaways     Layaway[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("customers")
}

model Sale {
  id                 String     @id @default(uuid())
  organizationId     String
  branchId           String
  terminalId         String
  shiftId            String?
  cashierSessionId   String
  customerId         String?
  // Client-generated UUID from the offline terminal - the idempotency key
  // for sync replay (DESIGN.md §6). Distinct from `id` so the server is
  // free to also assign its own id without colliding with client state.
  clientId           String     @unique
  status             SaleStatus @default(PENDING_SYNC)
  total              Decimal    @db.Decimal(12, 2)
  // Loyalty points earned/redeemed on this specific sale - denormalized
  // onto the sale (rather than only mutating Customer.loyaltyPoints) so
  // the sale receipt/history can always show what happened on that ticket
  // even after the customer's running balance has since moved on.
  pointsEarned       Int        @default(0)
  pointsRedeemed     Int        @default(0)
  priceDriftFlagged  Boolean    @default(false)
  createdAt          DateTime   @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  terminal       Terminal        @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  shift          Shift?          @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  cashierSession CashierSession  @relation(fields: [cashierSessionId], references: [id])
  cashier        OrgUser?        @relation("SaleCashier", fields: [cashierOrgUserId], references: [id])
  cashierOrgUserId String?
  customer       Customer?       @relation(fields: [customerId], references: [id])

  lineItems SaleLineItem[]
  payments  SalePayment[]
  discounts Discount[]
  refunds   Refund[]

  @@index([organizationId])
  @@index([branchId])
  @@map("sales")
}

model SaleLineItem {
  id         String  @id @default(uuid())
  saleId     String
  variantId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  taxAmount  Decimal @db.Decimal(12, 2) @default(0)

  sale    Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@map("sale_line_items")
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
  WALLET
}

model SalePayment {
  id                  String        @id @default(uuid())
  saleId              String
  method              PaymentMethod
  amount              Decimal       @db.Decimal(12, 2) // in org.baseCurrency
  providerReference   String?
  // M-Pesa always settles in KES regardless of org.baseCurrency - see
  // DESIGN.md §9. Both null for cash/card-in-base-currency payments.
  settlementCurrency  String?
  settlementAmount    Decimal?      @db.Decimal(12, 2)
  createdAt           DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_payments")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Discount {
  id         String       @id @default(uuid())
  saleId     String
  type       DiscountType
  value      Decimal      @db.Decimal(12, 2)
  approvedById String

  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  approvedBy OrgUser @relation("DiscountApprovedBy", fields: [approvedById], references: [id])

  @@index([saleId])
  @@map("discounts")
}

model Refund {
  id           String   @id @default(uuid())
  saleId       String
  amount       Decimal  @db.Decimal(12, 2)
  reason       String
  approvedById String
  createdAt    DateTime @default(now())

  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  approvedBy OrgUser @relation("RefundApprovedBy", fields: [approvedById], references: [id])

  @@index([saleId])
  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────────────────
// Layaway - a customer reserves items and pays them off over time before
// pickup. Deliberately does NOT hold/reserve inventory at creation (that
// would need a new inventory-transaction type just to represent a
// non-committal hold, and this pilot's stock-conflict philosophy is
// already "never block, reconcile after the fact" - DESIGN.md §6). Stock
// is only actually decremented at completion/pickup, via the same
// InventoryTransactionsService.recordInTx used by sales.
// ─────────────────────────────────────────────────────────────────────────

enum LayawayStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model Layaway {
  id             String        @id @default(uuid())
  organizationId String
  branchId       String
  customerId     String
  status         LayawayStatus @default(OPEN)
  total          Decimal       @db.Decimal(12, 2)
  depositPaid    Decimal       @db.Decimal(12, 2) @default(0)
  createdAt      DateTime      @default(now())
  completedAt    DateTime?
  cancelledAt    DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  lineItems    LayawayLineItem[]
  payments     LayawayPayment[]

  @@index([organizationId])
  @@index([branchId])
  @@map("layaways")
}

model LayawayLineItem {
  id        String  @id @default(uuid())
  layawayId String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  taxAmount Decimal @db.Decimal(12, 2) @default(0)

  layaway Layaway        @relation(fields: [layawayId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([layawayId])
  @@map("layaway_line_items")
}

model LayawayPayment {
  id        String        @id @default(uuid())
  layawayId String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  createdAt DateTime      @default(now())

  layaway Layaway @relation(fields: [layawayId], references: [id], onDelete: Cascade)

  @@index([layawayId])
  @@map("layaway_payments")
}

// ─────────────────────────────────────────────────────────────────────────
// Offline sync (DESIGN.md §6)
// ─────────────────────────────────────────────────────────────────────────

enum SyncStatus {
  PENDING
  APPLIED
  FAILED
}

model SyncOutbox {
  id         String     @id @default(uuid())
  terminalId String
  eventType  String
  payload    Json
  // The idempotency key - matches the client-generated id on the record the
  // event creates/mutates (e.g. Sale.clientId). Replays are safe no-ops.
  clientId   String     @unique
  status     SyncStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  appliedAt  DateTime?

  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@index([terminalId, status])
  @@map("sync_outbox")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit log — append-only. Nothing in this table is ever updated/deleted by
// application code.
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  terminalId     String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        OrgUser?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("audit_log")
}
